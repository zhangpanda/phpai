{
    "name": "zhangpanda/phpai",
    "description": "Attribute-driven, type-safe PHP AI framework with MCP support",
    "type": "library",
    "license": "Apache-2.0",
    "keywords": ["ai", "llm", "openai", "anthropic", "mcp", "agent", "php8", "attribute"],
    "authors": [
        {
            "name": "PHPAI Contributors"
        }
    ],
    "require": {
        "php": "^8.3",
        "guzzlehttp/guzzle": "^7.9",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.12"
    },
    "autoload": {
        "psr-4": {
            "PHPAI\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PHPAI\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "config": {
        "sort-packages": true
    }
}
