{
    "name": "synapse-php/laravel",
    "description": "Laravel integration for Synapse PHP AI framework",
    "type": "library",
    "license": "Apache-2.0",
    "require": {
        "php": "^8.3",
        "synapse-php/synapse": "^0.1",
        "illuminate/support": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Synapse\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Synapse\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Synapse\\Laravel\\SynapseServiceProvider"
            ]
        }
    }
}
