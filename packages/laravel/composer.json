{
    "name": "zhangpanda/phpai-laravel",
    "description": "Laravel integration for PHPAI PHP AI framework",
    "type": "library",
    "license": "Apache-2.0",
    "require": {
        "php": "^8.3",
        "zhangpanda/phpai": "^0.2",
        "illuminate/support": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "PHPAI\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PHPAI\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "PHPAI\\Laravel\\PHPAIServiceProvider"
            ]
        }
    }
}
